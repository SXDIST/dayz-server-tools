{
  "name": "dayz-tools",
  "version": "0.1.0",
  "description": "Electron launcher for DayZ server and mod workflows",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "next dev --webpack --hostname 127.0.0.1 --port 3210",
    "dev:web:turbo": "next dev",
    "dev:electron": "wait-on http-get://127.0.0.1:3210 && electron .",
    "build": "next build",
    "build:desktop": "npm run build && electron-builder",
    "build:desktop:dir": "npm run build && electron-builder --dir",
    "start": "electron .",
    "start:web": "next start",
    "lint": "eslint"
  },
  "dependencies": {},
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.dayztools.launcher",
    "productName": "DayZ Tools Launcher",
    "npmRebuild": false,
    "electronLanguages": [
      "en",
      "ru"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/node/dayz-backend.cjs",
        "to": "backend/node/dayz-backend.cjs"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "tar.gz",
        "dir"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "dir"
      ]
    }
  }
}
